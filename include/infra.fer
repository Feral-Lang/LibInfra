let io = import('std/io');
let fs = import('std/fs');
let os = import('std/os');
let vec = import('std/vec');
let json = import('std/json');
let result = import('std/result');
let logging = import('std/logging');

let ssh = import('ssh/ssh');

let Infra = struct(
    ssh = nil,
    chan = nil, # command execution channel
    sftp = nil, # sftp session
    distro = ''
);
Infra.setTypeName('Infra');

let depth = 1;

let pushDepth = fn() { ++depth; };
let popDepth = fn() { --depth; };

let ScopedDepth = struct();
ScopedDepth.setTypeName('ScopedDepth');
let _init_ in ScopedDepth = fn() { pushDepth(); };
let _deinit_ in ScopedDepth = fn() { popDepth(); };

let PathAttrs = struct(
    name = '',
    size = 0,
    perms = 0,
    mtime = 0,
    owner = '',
    uid = 0,
    group = '',
    gid = 0
);
PathAttrs.setTypeName('PathAttrs');

############################################## Utils ##############################################

let expect = fn(.kw, res, val = nil) {
    let nl = ref(kw['nl']) ?? true;
    if !res.isOk() {
        if nl { io.cprintln('{r}failed{0}'); }
        raise('error (', res.getVal().getCode(), '): ', res.getVal().getMsg());
    }
    if val != nil && res.getVal() != val {
        if nl { io.cprintln('{r}failed{0}'); }
        raise('in result, expected `', val, '`, found `', res.getVal(), '`');
    }
    return res.getVal();
};

let prefix = fn() {
    if depth == 1 {
        return '{bm}=>>';
    } elif depth == 2 {
        return '{bm}==>>';
    } elif depth == 3 {
        return '{bm}===>>';
    } elif depth == 4 {
        return '{bm}====>>';
    } elif depth == 5 {
        return '{bm}=====>>';
    }
    return '{bm}' + ('=' * depth) + '>>';
};

############################################## Core ###############################################

let new = fn(host, port = nil, user = nil) {
    let conn = ssh.new();
    io.cprint(prefix(), ' {y}connecting to remote {0}... ');
    expect(conn.setOpt(ssh.OPT_HOST, host));
    if port != nil { expect(conn.setOpt(ssh.OPT_PORT, port)); }
    if user != nil { expect(conn.setOpt(ssh.OPT_USER, user)); }
    expect(conn.connect());
    expect(ssh.verifyKnownHost(conn));
    expect(ssh.authenticate(conn));
    let chan = expect(conn.openChannel());
    let sftp = expect(conn.initSFTP());
    io.cprintln('{g}connected{0}');
    let obj = Infra(ref(conn), ref(chan), ref(sftp));
    let _ = ScopedDepth();
    obj.identifyDistro();
    return obj;
};

let install in Infra = fn(.kw, localPath, remotePath) {
    if fs.isReg(localPath) {
        return self.installFrom(kw..., localPath, remotePath);
    }
    let items = fs.walkDir(localPath, fs.WALK_RECURSE);
    items.sort();
    io.cprintln(prefix(), ' {y}installing everything in {c}', localPath, '{0} ...');
    let installed = 0;
    ++depth;
    for itemPath in items.each() {
        if self.installFrom(kw..., itemPath, remotePath / (itemPath.relativeTo(localPath))) {
            ++installed;
        }
    }
    --depth;
    if installed > 0 {
        io.cprintln(prefix(), ' {g}installed {c}', installed, '{0}/{c}', items.len(), ' {g}items in {c}', remotePath, '{0}');
        return true;
    }
    io.cprintln(prefix(), ' {g}all {c}', items.len(), ' {g}items are up to date in {c}', remotePath, '{0}');
    return false;
};

let installFrom in Infra = fn(.kw, localPath, remotePath) {
    let data = fs.fopen(localPath).readAll().trim();
    return self.installData(kw..., remotePath, data);
};

let installData in Infra = fn(.kw, remotePath, dataTmp) {
    let isTrunc = kw['trunc'] ?? false;
    let isTempl = kw['templ'] ?? false;
    inline if isTempl {
        let data = os.applyEnv(dataTmp);
    } else {
        let data = ref(dataTmp);
    }
    let parentDir = remotePath.parent();
    io.cprintln(prefix(), ' {y}installing {c}', remotePath, '{0} ...');
    ++depth;
    let updated = false;
    if !self.exists(kw..., remotePath) {
        ++depth;
        if !self.exists(kw..., parentDir) { self.mkdir(kw..., parentDir); }
        --depth;
        self.writeFile(kw..., remotePath, data);
        updated = true;
    } else {
        let existingData = self.readFile(kw..., remotePath);
        if (isTrunc && data != existingData) || (!isTrunc && existingData.find(data) < 0) {
            self.writeFile(kw..., remotePath, data);
            updated = true;
        }
    }
    --depth;
    if updated {
        io.cprintln(prefix(), ' {g}installed {c}', remotePath, '{0}');
    } else {
        io.cprintln(prefix(), ' {g}already up to date {c}', remotePath, '{0}');
    }
    return updated;
};

let getEnv in Infra = fn(.kw, var) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}getting env variable {c}', var, ' {0}... '); }
    let val = '';
    expect(self.exec(kw..., 'echo $' + var, out = val), 0);
    if show {
        if !val.empty() {
            io.cprintln('{g}', val, '{0}');
        } else {
            io.cprintln('{r}not found{0}');
        }
    }
    return val;
};

let exists in Infra = fn(.kw, path) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}checking if path {c}', path, ' {y}exists', ' {0}... '); }
    let val = expect(self.exec(kw..., 'test', '-e', path.str(), '||', 'test', '-L', path.str())) == 0;
    if show {
        if val {
            io.cprintln('{g}yes{0}');
        } else {
            io.cprintln('{r}no{0}');
        }
    }
    return val;
};

let isFile in Infra = fn(.kw, path) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}checking if path {c}', path, ' {y}is a file', ' {0}... '); }
    let val = expect(self.exec(kw..., 'test', '-f', path.str())) == 0;
    if show {
        if val {
            io.cprintln('{g}yes{0}');
        } else {
            io.cprintln('{r}no{0}');
        }
    }
    return val;
};

let isDir in Infra = fn(.kw, path) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}checking if path {c}', path, ' {y}is a dir', ' {0}... '); }
    let val = expect(self.exec(kw..., 'test', '-d', path.str())) == 0;
    if show {
        if val {
            io.cprintln('{g}yes{0}');
        } else {
            io.cprintln('{r}no{0}');
        }
    }
    return val;
};

let readFile in Infra = fn(.kw, path) {
    let show = kw['show'] ?? true;
    let sudo = kw['su'] ?? false;
    let tmpPath = path.str();
    let isReadingTmp = '';
    if sudo {
        let _ = ScopedDepth();
        tmpPath = '/tmp/tmpRead-' + tmpPath.replace('/', '@--@');
        self.copy(kw..., show = false, path, tmpPath);
        self.chmod(kw..., show = false, tmpPath, '+rx');
        isReadingTmp = ' temp';
    }
    if show { io.cprint(prefix(), ' {y}reading', isReadingTmp, ' file {c}', tmpPath, ' {0}... '); }
    let f = self.sftp.openFile(tmpPath);
    let data = expect(self.sftp.readFile(f)).trim();
    expect(f.close());
    if show { io.cprintln('{c}', data.len(), ' {g}bytes{0}'); }
    if sudo {
        let _ = ScopedDepth();
        self.remove(kw..., tmpPath);
    }
    return data;
};

let writeFile in Infra = fn(.kw, path, data, perms = 0644) {
    let show = kw['show'] ?? true;
    let sudo = kw['su'] ?? false;
    let isTrunc = kw['trunc'] ?? false;

    let tmpPath = path.str();
    if sudo {
        tmpPath = '/tmp/tmpWrite-' + tmpPath.replace('/', '@--@');
        if show { io.cprint(prefix(), ' {y}writing data to temp file {c}', tmpPath, ' {0}... '); }
    } else {
        if show { io.cprint(prefix(), ' {y}writing data to file {c}', tmpPath, ' {0}... '); }
    }
    let openFlags = fs.O_CREAT | fs.O_WRONLY;
    if isTrunc { openFlags |= fs.O_TRUNC; }
    else { openFlags |= fs.O_APPEND; }
    let f = self.sftp.openFile(tmpPath, openFlags, perms);
    let writtenBytes = expect(self.sftp.writeFile(f, data));
    expect(f.close());
    if show { io.cprintln('{c}', writtenBytes, ' {g}bytes{0}'); }
    if sudo {
        let _ = ScopedDepth();
        if isTrunc {
            self.move(kw..., tmpPath, path);
        } else {
            self.cat(kw..., tmpPath, path);
            self.remove(kw..., tmpPath);
        }
        self.chown(kw..., path, 'root');
    }
    return writtenBytes;
};

let appendFile in Infra = fn(.kw, path, data, perms = 0640) {
    return self.writeFile(kw..., append = true, path, data, perms);
};

let walkDir in Infra = fn(.kw, path, regex = '', recursive = true) {
    let show = kw['show'] ?? true;
    let dirOnly = kw['dirOnly'] ?? false;
    let fileOnly = kw['fileOnly'] ?? false;
    let exists = self.exists(kw..., show = false, path);
    if !exists {
        expect(nl = false, result.err(-1, 'path doesn\'t exist'));
    }
    let cmd = 'find ' + path.str();
    if !recursive {
        cmd += ' -maxdepth 1';
    }
    if !regex.empty() {
        cmd += ' -path "' + regex + '"';
    }
    if show { io.cprint(prefix(), ' {y}getting entries in {c}', path, ' {0}... '); }
    let entries = vec.new(refs = true);
    let entriesStr = '';
    expect(self.exec(kw..., out = entriesStr, cmd), 0);
    for e in entriesStr.split('\n').each() {
        if e == path.str() { continue; }
        if fileOnly && !self.isFile(show = false, e) { continue; }
        if dirOnly && !self.isDir(show = false, e) { continue; }
        entries.push(e.path());
    }
    if show { io.cprintln('{c}', entries.len(), ' {g}found{0}'); }
    return entries;
};

let stat in Infra = fn(.kw, path) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}getting stat info for {c}', path, ' {0}... '); }
    let exists = self.exists(kw..., show = false, path);
    if !exists {
        expect(nl = false, result.err(-1, 'path doesn\'t exist'));
    }
    let statDataStr = self.execOut(kw..., 'stat', '--format="%n %s %a %Y %U %u %G %g"', path.str());
    let st = statDataStr.split(' ');
    if show { io.cprintln('{g}found{0}'); }
    return PathAttrs(st[0], st[1].int(), st[2].int(8), st[3].int(), st[4], st[5].int(), st[6], st[7].int());
};

let mkdir in Infra = fn(.kw, paths...) {
    let show = kw['show'] ?? true;
    for path in paths.each() {
        if show { io.cprint(prefix(), ' {y}creating directory {c}', path, ' {0}... '); }
        let exists = self.exists(kw..., show = false, path);
        if exists {
            if show { io.cprintln('{g}already exists{0}'); }
            continue;
        }
        let res = self.exec(kw..., 'mkdir -p ' + path.str());
        expect(res, 0);
        if show { io.cprintln('{g}done{0}'); }
    }
};

let mklink in Infra = fn(.kw, src, dest) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}linking {c}', src, ' {0}-> {c}', dest, ' {0}... '); }
    expect(self.exec(kw..., 'ln', '-sf', src.str(), dest.str()), 0);
    if show { io.cprintln('{g}done{0}'); }
};

let remove in Infra = fn(.kw, paths...) {
    let show = kw['show'] ?? true;
    for path in paths.each() {
        if show { io.cprint(prefix(), ' {y}removing path {c}', path, ' {0}... '); }
        let exists = self.exists(kw..., show = false, path);
        if !exists {
            if show { io.cprintln('{g}doesn\'t exist{0}'); }
            continue;
        }
        expect(self.exec(kw..., 'rm -rf ' + path.str()), 0);
        if show { io.cprintln('{g}done{0}'); }
    }
};

let copy in Infra = fn(.kw, src, dest) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}copying {c}', src, ' {0}-> {c}', dest, ' {0}... '); }
    expect(self.exec(kw..., 'cp', '-r', src.str(), dest.str()), 0);
    if show { io.cprintln('{g}done{0}'); }
};

let move in Infra = fn(.kw, src, dest) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}moving {c}', src, ' {0}-> {c}', dest, ' {0}... '); }
    expect(self.exec(kw..., 'mv', src.str(), dest.str()), 0);
    if show { io.cprintln('{g}done{0}'); }
};

let chmod in Infra = fn(.kw, path, perms) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}changing perms for {c}', path, ' {0}... '); }
    expect(self.exec(kw..., 'chmod', '-R', perms, path.str()), 0);
    if show { io.cprintln('{g}done{0}'); }
};

let chown in Infra = fn(.kw, path, user, groupOptional = nil) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}changing ownership for {c}', path, ' {0}... '); }
    let group = user;
    if groupOptional != nil { group = groupOptional; }
    expect(self.exec(kw..., 'chown', '-R', user + ':' + group, path.str()), 0);
    if show { io.cprintln('{g}done{0}'); }
};

let cat in Infra = fn(.kw, src, dest) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}appending {c}', src, ' {0}-> {c}', dest, ' {0}... '); }
    expect(self.exec(kw..., 'cat', src.str(), '>>', dest.str()), 0);
    if show { io.cprintln('{g}done{0}'); }
};

let getIP in Infra = fn(.kw) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}fetching ip address {0}... '); }
    let output = self.execOut(kw..., 'ip', '-json', 'route', 'get', '1.1.1.1');
    let js = json.loads(output);
    let ip = js[0]['prefsrc'];
    if show { io.cprintln('{g}', ip, '{0}'); }
    return ip;
};

let download in Infra = fn(.kw, url, dest) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}downloading to {c}', dest, ' {0}... '); }
    expect(self.exec(kw..., 'curl', '-sL', '-o', dest.str(), url), 0);
    if show { io.cprintln('{g}done{0}'); }
};

let identifyDistro in Infra = fn(.kw) {
    let show = kw['show'] ?? true;
    if show { io.cprint(prefix(), ' {y}identifying distro {0}... '); }
    let releaseOut = self.execOut(kw..., 'cat', '/etc/*-release');
    self.distro = 'unknown';
    if releaseOut.find('arch') >= 0 {
        self.distro = 'arch';
    } elif releaseOut.find('ubuntu') >= 0 {
        self.distro = 'ubuntu';
    } elif releaseOut.find('debian') >= 0 {
        self.distro = 'debian';
    } elif releaseOut.find('gentoo') >= 0 {
        self.distro = 'gentoo';
    } elif releaseOut.find('centos') >= 0 {
        self.distro = 'centos';
    } elif releaseOut.find('suse') >= 0 {
        self.distro = 'suse';
    }
    if show {
        if self.distro == 'unknown' {
            io.cprintln('{r}', self.distro, '{0}');
        } else {
            io.cprintln('{g}', self.distro, '{0}');
        }
    }
};

let installPackages in Infra = fn(.kw, packages...) {
    let show = kw['show'] ?? true;
    let pkgCmd = '';
    if self.distro == 'arch' {
        pkgCmd = 'pacman -S --needed --noconfirm';
    } elif self.distro == 'ubuntu' || self.distro == 'debian' {
        pkgCmd = 'apt install -y';
    }
    if pkgCmd.empty() {
        raise('unknown package command for distro: ', self.distro);
    }
    if show { io.cprintln(prefix(), ' {y}installing packages {c}', packages.join('{0}, {c}'), ' {0}... '); }
    expect(nl = false, self.exec(kw..., pkgCmd, packages...), 0);
    if show { io.cprintln(prefix(), ' {g}installation completed{0}'); }
};

let updatePackages in Infra = fn(.kw) {
    let show = kw['show'] ?? true;
    let pkgCmd = '';
    if self.distro == 'arch' {
        pkgCmd = 'pacman -Syu --noconfirm';
    } elif self.distro == 'ubuntu' || self.distro == 'debian' {
        pkgCmd = 'apt update && apt upgrade';
    }
    if pkgCmd.empty() {
        raise('unknown package command for distro: ', self.distro);
    }
    if show { io.cprintln(prefix(), ' {y}Updating packages {0}... '); }
    expect(nl = false, self.exec(kw..., pkgCmd), 0);
    if show { io.cprintln(prefix(), ' {g}installation completed{0}'); }
};

let run in Infra = fn(.kw, command...) {
    let desc = ref(kw['desc']);
    let out = ref(kw['out']);
    if desc != nil {
        io.cprint(prefix(), ' {y}', desc, ' {0}... ');
        if out == nil { io.cprintln(); }
    }
    expect(nl = out != nil, self.exec(kw..., command...), 0);
    if desc != nil {
        if out == nil { io.cprint(prefix(), ' '); }
        io.cprintln('{g}done{0}');
    }
};

let exec in Infra = fn(.kw, command...) {
    let sudo = kw['su'];
    let cmd = '';
    if sudo {
        cmd += 'sudo su - -c \'';
    }
    cmd += command.join(' ');
    if sudo { cmd += '\''; }
    logging.trace('executing command: ', cmd);
    return self.chan.exec(kw..., cmd);
};

let execOut in Infra = fn(.kw, command...) {
    let val = '';
    expect(self.exec(kw..., out = val, command...), 0);
    return val;
};

let getDistro in Infra = fn() { return self.distro; };